# PostgreSQL — API/app (escrita permitida apenas pelo produto)
DATABASE_URL=postgresql://taskflow:taskflow@localhost:5432/taskflow?schema=public

# PostgreSQL — tooling/agente Cursor (SOMENTE LEITURA; nunca use para mutações)
DATABASE_URL_READONLY=postgresql://taskflow_readonly:taskflow_readonly@localhost:5432/taskflow?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# API
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3001
