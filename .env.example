# PostgreSQL — API/app (escrita permitida apenas pelo produto)
DATABASE_URL=postgresql://taskflow:taskflow@localhost:5433/taskflow?schema=public
POSTGRES_PASSWORD=taskflow

# PostgreSQL — tooling/agente Cursor (SOMENTE LEITURA; nunca use para mutações)
DATABASE_URL_READONLY=postgresql://taskflow_readonly:taskflow_readonly@localhost:5433/taskflow?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Administrador principal — promovido automaticamente ao entrar/cadastrar
ADMIN_EMAIL=rneves@beautyservices.com.br

# API
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# Web / rede interna
# No servidor LAN, troque pelo IP fixo da máquina hospedeira.
PUBLIC_APP_URL=http://localhost:3080
# Destino server-side do proxy Next.js. O Compose define http://api:3001.
INTERNAL_API_URL=http://localhost:3001

# Portas no host (Compose)
# - Web LAN: 3080 (evita conflito com outras apps na 3000)
# - Postgres local tooling: 5433 (API usa postgres:5432 na rede Docker)

# E-mail — necessário para enviar relatórios PDF à equipe
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TaskFlow <taskflow@example.com>
REPORT_MAX_DAYS=366
REPORT_MAX_TASKS=1000
REPORT_MAX_RECIPIENTS=50
